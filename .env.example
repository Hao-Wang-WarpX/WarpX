# ===== HTTP 客户端 =====
# Chrome UA 一般不会被目标站 403
WEB_MCP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
WEB_MCP_HTTP_TIMEOUT=30
# 例: http://127.0.0.1:7890 (verge-mihomo) - 留空表示直连
WEB_MCP_PROXY=

# ===== Playwright =====
WEB_MCP_BROWSER_TIMEOUT=45
WEB_MCP_BROWSER_HEADLESS=true
# 可选: 等指定 CSS selector 出现再抓 (e.g. "article")
WEB_MCP_BROWSER_WAIT_SELECTOR=
WEB_MCP_BROWSER_VIEWPORT=1280,720

# ===== 下载 =====
WEB_MCP_DOWNLOAD_DIR=D:\桌面\web-mcp\downloads
WEB_MCP_MAX_IMAGE_SIZE_MB=10

# ===== 搜索 =====
# DDG region: wt-wt 全球, us-en 美国, cn-zh 中国, jp-ja 日本 ...
WEB_MCP_DDG_REGION=wt-wt
WEB_MCP_DDG_SAFESEARCH=moderate
